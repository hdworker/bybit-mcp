# =============================================================================
# Bybit MCP — environment configuration
# Copy to .env and fill in. .env is git-ignored.
# =============================================================================

# ---- Connection --------------------------------------------------------------
# testnet=true|false — false = https://api.bybit.com, true = https://api-testnet.bybit.com
BYBIT_TESTNET=false

# Connection timeouts (seconds)
BYBIT_HTTP_TIMEOUT=10
BYBIT_RECV_WINDOW=5000

# ---- API credentials ---------------------------------------------------------
# Required for private endpoints (positions, orders, wallet).
# Public endpoints (kline, tickers, orderbook, funding) work without keys.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ---- Vibe-Trading integration -----------------------------------------------
# Path to the runtime root. The MCP server reads the committed mandate
# (live/mandate.json), kill switch (live/halt), audit ledger (live/audit.jsonl),
# and trade counter (live/trade_counter.json) from this directory.
#
# Default = ~/.vibe-trading — the same root the Vibe-Trading CLI uses.
VIBE_RUNTIME_ROOT=~/.vibe-trading

# If true, the MCP server will REJECT every order-writing tool call when no
# valid mandate is committed. Disable only for pure paper / read-only mode.
VIBE_REQUIRE_MANDATE_FOR_WRITES=true

# ---- Logging -----------------------------------------------------------------
BYBIT_LOG_LEVEL=INFO
